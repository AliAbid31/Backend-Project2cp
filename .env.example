DATABASE_URL=postgresql://username:password@host:5432/database?sslmode=require

CHATBOT_LLM_PROVIDER=gemini

# Google Gemini
GOOGLE_API_KEY=your-google-api-key
CHATBOT_GEMINI_MODEL=gemini-2.5-flash

CHATBOT_OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
SECRET_KEY = your-extremely-secret-hex-code
ALGORITHM = "HS256"
ACCESS_TOKEN_EXPIRE_MINUTES = 20160 
# =========================
# EMAIL (optional)
# =========================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_ADDRESS=tutorly.project@gmail.com
EMAIL_PASSWORD=your-app-password
SENDER_NAME=TutoratUp
ENABLE_EMAIL_DEBUG=false
MAX_EMAIL_RETRIES=3